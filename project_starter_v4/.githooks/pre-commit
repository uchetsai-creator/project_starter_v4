#!/usr/bin/env bash
# project_starter_v4 — verification pre-commit hook (Phase 20)
# Runs verify_docs.py --content on every git commit. Blocks on failure.
#
# Install (once per project clone):
#   cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Requires .project-starter.yml at the project root with:
#   project_type: <your-type>
#   docs_path: docs/

set -euo pipefail

CONFIG=".project-starter.yml"
PROJECT_TYPE=""
DOCS_PATH="docs"

if [ -f "$CONFIG" ]; then
    PROJECT_TYPE=$(grep '^project_type:' "$CONFIG" | sed 's/project_type:[[:space:]]*//' | tr -d ""' ")
    DOCS_CANDIDATE=$(grep '^docs_path:' "$CONFIG" | sed 's/docs_path:[[:space:]]*//' | tr -d ""' /")
    [ -n "$DOCS_CANDIDATE" ] && DOCS_PATH="$DOCS_CANDIDATE"
fi

if [ -z "$PROJECT_TYPE" ]; then
    echo "⚠️  pre-commit: .project-starter.yml not found or project_type missing — skipping verification."
    exit 0
fi

echo "pre-commit: project-type=$PROJECT_TYPE  docs=$DOCS_PATH"
PASS=true

# 1. Document completeness + content quality (Phase 17)
if command -v python3 &>/dev/null && [ -f "docs/script/verify_docs.py" ]; then
    echo "  → verify_docs.py --content ..."
    python3 "docs/script/verify_docs.py" \
        --project-type "$PROJECT_TYPE" --docs "$DOCS_PATH" --content --strict 2>&1 || PASS=false
else
    echo "  ⚠️  docs/script/verify_docs.py not found — skipping"
fi

# 2. Log quality (Phase 23 — skipped until script ships)
if [ -f "docs/script/verify_logs.py" ]; then
    echo "  → verify_logs.py ..."
    python3 "docs/script/verify_logs.py" --project-type "$PROJECT_TYPE" --strict 2>&1 || PASS=false
fi

# 3. Test report quality (Phase 23 — skipped until script ships)
if [ -f "docs/script/verify_tests.py" ]; then
    echo "  → verify_tests.py ..."
    python3 "docs/script/verify_tests.py" \
        --project-type "$PROJECT_TYPE" --docs "$DOCS_PATH" --strict 2>&1 || PASS=false
fi

if [ "$PASS" = false ]; then
    echo ""
    echo "❌  pre-commit: verification failed — commit blocked."
    echo "    Fix the issues above, then re-run: git commit"
    exit 1
fi

echo "✅  pre-commit: all checks passed."
